generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model User {
  id          String   @id @default(cuid())
  displayName String?
  nickname    String?  @unique
  intro       String?
  avatarUrl   String?
  walletAddress String?
  walletAddressNormalized String? @unique
  walletProvider String?
  creditBalance Int      @default(0)
  createdAt   DateTime @default(now())

  battles Battle[]
  entries Entry[]
  reports Report[]
  walletChallenges WalletChallenge[]
  creditTransactions CreditTransaction[]
  socialComments SocialComment[]
  entryLikes EntryLike[]
  battleLikes BattleLike[]
  participations BattleParticipation[]
  battleShares BattleShare[]
  notifications Notification[]

  @@map("users")
}

model Battle {
  id                String       @id @default(cuid())
  battleType        String       @db.VarChar(32)
  status            String       @default("OPEN") @db.VarChar(32)
  prompt            String?
  title             String?
  description       String?
  imageUrl          String?
  deadlineAt        DateTime?
  isAnonymous       Boolean      @default(false)
  recommendedScore  Int          @default(50)
  createdByUserId   String
  failureReason     String?
  createdAt         DateTime     @default(now())
  closedAt          DateTime?
  judgingStartedAt  DateTime?
  settledAt         DateTime?

  createdBy User           @relation(fields: [createdByUserId], references: [id])
  options   BattleOption[]
  entries   Entry[]
  rules     JudgingRule[]
  verdict   Verdict?
  settlement Settlement?
  reports   Report[]
  socialComments SocialComment[]
  likes     BattleLike[]
  participations BattleParticipation[]
  shares    BattleShare[]
  notifications Notification[]

  @@index([battleType])
  @@index([status])
  @@map("battles")
}

model BattleOption {
  id        String   @id @default(cuid())
  battleId  String
  text      String
  createdAt DateTime @default(now())

  battle  Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
  entries Entry[]
  participations BattleParticipation[]

  @@index([battleId])
  @@map("battle_options")
}

model Entry {
  id                String   @id @default(cuid())
  battleId          String
  optionId          String?
  parentEntryId     String?
  content           String
  submittedByUserId String
  createdAt         DateTime @default(now())

  battle      Battle        @relation(fields: [battleId], references: [id], onDelete: Cascade)
  option      BattleOption? @relation(fields: [optionId], references: [id])
  parentEntry Entry?        @relation("EntryReplies", fields: [parentEntryId], references: [id], onDelete: Cascade)
  replies     Entry[]       @relation("EntryReplies")
  submittedBy User         @relation(fields: [submittedByUserId], references: [id])
  socialComments SocialComment[]
  likes       EntryLike[]
  participations BattleParticipation[]

  @@index([battleId])
  @@index([optionId])
  @@index([parentEntryId])
  @@map("entries")
}

model BattleParticipation {
  id                  String   @id @default(cuid())
  battleId            String
  userId              String
  optionId            String?
  entryId             String?
  costCredits         Int
  creditTransactionId String?
  rewardClaimedAt     DateTime?
  createdAt           DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  option BattleOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  entry  Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@unique([battleId, userId])
  @@index([userId])
  @@index([entryId])
  @@map("battle_participations")
}

model WalletChallenge {
  id                      String    @id @default(cuid())
  userId                  String?
  walletAddress           String
  walletAddressNormalized String
  walletProvider          String?
  nonce                   String
  message                 String
  issuedAt                DateTime  @default(now())
  expiresAt               DateTime
  usedAt                  DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([walletAddressNormalized])
  @@index([expiresAt])
  @@map("wallet_challenges")
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  reason       String
  balanceAfter Int
  metadataJson Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_transactions")
}

model SocialComment {
  id             String   @id @default(cuid())
  battleId       String
  targetEntryId  String?
  authorUserId   String
  content        String
  createdAt      DateTime @default(now())

  battle      Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  targetEntry Entry? @relation(fields: [targetEntryId], references: [id], onDelete: Cascade)
  author      User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([battleId])
  @@index([targetEntryId])
  @@index([authorUserId])
  @@map("social_comments")
}

model EntryLike {
  id        String   @id @default(cuid())
  entryId   String
  userId    String
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@index([userId])
  @@map("entry_likes")
}

model BattleLike {
  id        String   @id @default(cuid())
  battleId  String
  userId    String
  createdAt DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId])
  @@index([userId])
  @@map("battle_likes")
}

model BattleShare {
  id        String   @id @default(cuid())
  battleId  String
  userId    String?
  channel   String?
  createdAt DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([battleId])
  @@index([userId])
  @@map("battle_shares")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  battleId  String?
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  battle Battle? @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([battleId])
  @@map("notifications")
}

model JudgingRule {
  id        String   @id @default(cuid())
  battleId  String
  rulesJson Json
  rulesHash String
  createdAt DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@index([battleId])
  @@map("judging_rules")
}

model Verdict {
  id           String   @id @default(cuid())
  battleId     String   @unique
  judgeOutput  Json
  hashPackage  Json
  modelVersion String
  createdAt    DateTime @default(now())

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@map("verdicts")
}

model Settlement {
  id               String   @id @default(cuid())
  battleId          String   @unique
  chainId           Int
  contractAddress   String
  txHash            String
  explorerUrl       String
  contentHash       String
  optionsHash       String?
  entriesRoot       String
  rulesHash         String
  modelVersionHash  String
  winnerHash        String
  mvpEntryHash      String?
  verdictHash       String
  settledAt         DateTime
  payloadJson       Json

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@index([chainId])
  @@index([txHash])
  @@map("settlements")
}

model Report {
  id                String       @id @default(cuid())
  battleId          String
  reporterUserId    String
  targetEntryId     String?
  reason            String
  status            ReportStatus @default(OPEN)
  createdAt         DateTime     @default(now())
  reviewedAt        DateTime?

  battle   Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterUserId], references: [id])

  @@index([battleId])
  @@index([status])
  @@map("reports")
}
