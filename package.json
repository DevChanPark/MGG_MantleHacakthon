{
  "name": "mgg-mantle-hackathon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node apps/api/src/server.js",
    "test": "node --test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:status": "docker compose ps",
    "db:logs": "docker compose logs postgres",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prisma:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
