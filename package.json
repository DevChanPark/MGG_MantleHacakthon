{
  "name": "mgg-mantle-hackathon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node apps/api/src/server.js",
    "test": "node --test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:status": "docker compose ps",
    "db:logs": "docker compose logs postgres",
    "prisma:generate": "node scripts/prisma.js generate",
    "prisma:validate": "node scripts/prisma.js validate --schema prisma/schema.prisma",
    "prisma:status": "node scripts/prisma.js migrate status --schema prisma/schema.prisma",
    "prisma:deploy": "node scripts/prisma.js migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate": "node scripts/prisma.js migrate dev --schema prisma/schema.prisma",
    "seed:demo": "node scripts/seed-demo-battles.js",
    "smoke:api": "node scripts/smoke-api-flow.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
